{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Polly": "Error"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "./logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 1,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff} {Level:u3}] {Message:lj}{NewLine}{Exception}",
          "hooks": "LSTY.Sdtd.ServerAdmin.WebApi.SerilogHooks::MyArchiveHooks, LSTY.Sdtd.ServerAdmin.WebApi"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "PathBase": "",
  "EnableRequestLog": true,
  "EnableSwagger": true,
  "EnableCors": true,
  "AllowedOrigins": [],
  "RavenOptions": {
    "Urls": [ "http://172.16.168.88:8080" ],
    "DatabaseName": "LSTY.Sdtd.ServerAdmin"
  },
  "Urls": "http://*:8089"
}
